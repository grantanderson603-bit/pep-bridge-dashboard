{
  "manifest_version": 3,
  "name": "PEP Bridge",
  "version": "1.0.0",
  "description": "Real-time data sync bridge for Hilton PEP",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://*.hilton.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.hilton.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
